{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "address": {
          "type": "string",
          "description": "The user's address."
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "The user's birth date."
        },
        "isLunar": {
          "type": "boolean",
          "description": "Whether the birth date is lunar."
        },
        "anniversary": {
          "type": "string",
          "format": "date",
          "description": "The user's wedding anniversary."
        },
        "preferences": {
          "type": "object",
          "properties": {
            "food": {
              "type": "string"
            },
            "hobbies": {
              "type": "string"
            }
          }
        },
        "avatarUrl": {
          "type": "string",
          "format": "uri"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the user is an administrator."
        }
      },
      "required": [
        "name",
        "email"
      ]
    },
    "Rule": {
      "title": "Rule",
      "description": "A rule for the group.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "description": "The title of the rule."
        },
        "content": {
          "type": "string",
          "description": "The content of the rule."
        }
      },
      "required": [
        "id",
        "title",
        "content"
      ]
    },
    "InspirationalMessage": {
      "title": "Inspirational Message",
      "description": "An inspirational message from a member.",
      "type": "object",
      "properties": {
        "author": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the message was created."
        }
      },
      "required": [
        "author",
        "content"
      ]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "An image or video in the gallery.",
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL of the image or video in Firebase Storage."
        },
        "storagePath": {
          "type": "string",
          "description": "The path of the file in Firebase Storage."
        },
        "contentType": {
          "type": "string",
          "description": "The MIME type of the file."
        },
        "description": {
          "type": "string",
          "description": "Description of the item."
        },
        "uploaderId": {
          "type": "string",
          "description": "The UID of the user who uploaded the item."
        },
        "uploaderName": {
          "type": "string",
          "description": "The name of the user who uploaded the item."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the item was created."
        }
      },
      "required": [
        "url",
        "storagePath",
        "contentType",
        "uploaderId",
        "uploaderName",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "email-password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores public profiles for all users."
    },
    "/rules/{ruleId}": {
      "schema": {
        "$ref": "#/entities/Rule"
      },
      "description": "Stores the group's rules."
    },
    "/messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/InspirationalMessage"
      },
      "description": "Stores inspirational messages from members."
    },
    "/gallery/{galleryItemId}": {
      "schema": {
        "$ref": "#/entities/GalleryItem"
      },
      "description": "Stores gallery items (images and videos)."
    }
  }
}
